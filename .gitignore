# Vivado runtime artefacts
.Xil/
vivado.jou
vivado.log
vivado_*.backup.jou
vivado_*.backup.log
*.str
*.wdb

# Generated project directories (Vivado regenerates these from create_project.tcl)
*.sim/
*.cache/
*.runs/
*.hw/
*.ip_user_files/

# Tool-generated backup snapshots used by switch_routing.sh / run_exp1_sweep.sh
src/*.orig
src/torus_4x4.sv.orig
src/router_fifo.sv.orig

# Python / Jupyter
__pycache__/
.ipynb_checkpoints/
*.pyc

# Per-sim TCL/log artefacts. A handful of representative samples are checked
# in; the full 345-sim trove is regenerated by run_full_rerun.sh.
#
# The "!" lines re-include the curated samples so they're tracked.
claude_stratchpad_workpsace/tcl/*
claude_stratchpad_workpsace/logs/*
!claude_stratchpad_workpsace/tcl/exp1_run_Custom_8.tcl
!claude_stratchpad_workpsace/tcl/exp1_run_XY_8.tcl
!claude_stratchpad_workpsace/tcl/exp1_run_Odd-Even_8.tcl
!claude_stratchpad_workpsace/tcl/Custom_UNIFORM_RANDOM_BP70_HOT10_FIFO8_SIM60000.tcl
!claude_stratchpad_workpsace/tcl/XY_BIT_COMPLEMENT_BP70_HOT10_FIFO8_SIM60000.tcl
!claude_stratchpad_workpsace/tcl/Custom_HOTSPOT_BP70_HOT50_FIFO8_SIM400000.tcl
!claude_stratchpad_workpsace/tcl/Custom_MATRIX_TRANSPOSE_BP20_HOT10_FIFO8_SIM500000.tcl
!claude_stratchpad_workpsace/tcl/Odd-Even_BIT_COMPLEMENT_BP70_HOT10_FIFO1_SIM200000.tcl
!claude_stratchpad_workpsace/tcl/Custom_HOTSPOT_BP20_HOT90_FIFO8_SIM1000000.tcl
!claude_stratchpad_workpsace/tcl/Custom_UNIFORM_RANDOM_BP70_HOT10_FIFO8_SIM1000000.tcl
!claude_stratchpad_workpsace/logs/exp1_run_Custom_8.log
!claude_stratchpad_workpsace/logs/exp1_run_XY_8.log
